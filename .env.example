# MongoDB Connection String
# Replace with your Atlas connection string or local Docker URI

# Atlas (cloud)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/

# Docker (local) — uncomment this and comment out Atlas URI if using Docker
# MONGODB_URI=mongodb://admin:changeme@localhost:27017/

# Docker Compose credentials (used by docker-compose.yml)
# Change these before running Docker in any shared environment
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme
ME_USERNAME=admin
ME_PASSWORD=changeme
